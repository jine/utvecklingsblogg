# Pooled connection for your application (note the -pooler suffix)
DATABASE_URL='postgresql://x:y@instance-pooler.eu-west-2.aws.neon.tech/dbname?sslmode=require&channel_binding=require'

# Direct connection for Prisma CLI (migrations, introspection)
DIRECT_URL='postgresql://x:y@instance.eu-west-2.aws.neon.tech/dbname?sslmode=require&channel_binding=require'

# Google OAuth credentials for authentication
AUTH_GOOGLE_ID=replace-with-your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=replace-with-your-google-client-secret

# Application URL (used for redirects in authentication)q
NEXT_PUBLIC_APP_URL=https://localhost:3000
BETTER_AUTH_URL=${NEXT_PUBLIC_APP_URL}