{
    "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": true,
        "includes": [
            "**",
            "!node_modules",
            "!.next",
            "!dist",
            "!build",
            "!**/*.md",
            "!src/app/globals.css",
            "!src/generated",
            "!src/components/tiptap-icons",
            "!src/components/tiptap-templates",
            "!src/components/tiptap-extension",
            "!src/components/tiptap-node",
            "!src/components/tiptap-ui-primitive",
            "!src/hooks",
            "!src/lib/tiptap-utils.ts",
            "!src/lib/auth.ts",
            "!src/lib/db.ts"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "security": {
                "noDangerouslySetInnerHtml": "off"
            },
            "suspicious": {
                "noUnknownAtRules": "off"
            },
            "correctness": {
                "noUnusedFunctionParameters": "off"
            }
        },
        "domains": {
            "next": "recommended",
            "react": "recommended"
        }
    },
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}
